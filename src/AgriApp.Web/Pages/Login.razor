@page "/login"
@layout AgriApp.Web.Layout.LoginLayout
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Sign In — AgriApp</PageTitle>

<MudGrid Justify="Justify.Center" Class="mt-12">
    <MudItem xs="12" sm="8" md="5" lg="4">
        <MudCard Elevation="4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Align="Align.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Agriculture" Class="mr-1" />
                        AgriApp Portal
                    </MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                        Agricultural Equipment Management
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
                    <DataAnnotationsValidator />

                    <MudTextField @bind-Value="_model.Email"
                                  Label="Email Address"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  Class="mb-3"
                                  For="@(() => _model.Email)" />

                    <MudTextField @bind-Value="_model.Password"
                                  Label="Password"
                                  InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                                  Class="mb-4"
                                  For="@(() => _model.Password)" />

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Disabled="_loading"
                               Class="mb-2">
                        @if (_loading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Signing in...</span>
                        }
                        else
                        {
                            <span>Sign In</span>
                        }
                    </MudButton>
                </EditForm>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private readonly LoginRequest _model = new();
    private bool _loading;
    private bool _showPassword;

    private async Task HandleLoginAsync()
    {
        _loading = true;
        try
        {
            var result = await AuthService.LoginAsync(_model);
            if (result?.Token != null)
            {
                var dest = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : Uri.UnescapeDataString(ReturnUrl);
                Nav.NavigateTo(dest, forceLoad: false);
            }
            else
            {
                Snackbar.Add("Login failed — invalid credentials.", Severity.Error);
            }
        }
        catch (HttpRequestException ex) when ((int?)ex.StatusCode == 401)
        {
            Snackbar.Add("Invalid email or password.", Severity.Error);
        }
        catch (HttpRequestException ex) when ((int?)ex.StatusCode == 400)
        {
            Snackbar.Add("Bad request — check your inputs and try again.", Severity.Warning);
        }
        catch (HttpRequestException ex) when ((int?)ex.StatusCode == 403)
        {
            Snackbar.Add("Access denied.", Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to connect to the server. Please try again.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
