@using AgriApp.Core.Enums
@using AgriApp.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IEquipmentService EquipmentService
@inject IVendorService VendorService
@inject AuthenticationStateProvider AuthStateProvider
@inject ICenterService CenterService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <EditForm id="eqForm" Model="_form" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <MudStack Spacing="3">
                @if (IsCreate && _headerCenter != null)
                {
                    <MudText Typo="Typo.subtitle1">
                        Adding equipment to: @_headerCenter.Name (@_headerCenter.CurrencySymbol)
                    </MudText>
                }

                <MudTextField @bind-Value="_form.Name" Label="Name" FullWidth="true"
                              For="@(() => _form.Name)" />

                <MudSelect @bind-Value="_form.Category" Label="Category" FullWidth="true">
                    @foreach (var cat in Enum.GetValues(typeof(EquipmentCategory)).Cast<EquipmentCategory>())
                    {
                        <MudSelectItem Value="@cat.ToString()">@cat</MudSelectItem>
                    }
                </MudSelect>

                <MudNumericField @bind-Value="_form.HourlyRate" Label="@($"Hourly Rate ({CurrencySymbol})")"
                                 Format="N2" FullWidth="true"
                                 For="@(() => _form.HourlyRate)" />

                @if (IsCreate && _isSuperUser)
                {
                    <MudSelect T="int" Value="_form.CenterId" ValueChanged="OnCreateCenterChangedAsync"
                               Label="Center"
                               FullWidth="true" Disabled="_loadingCenters">
                        @foreach (var c in _centerList)
                        {
                            <MudSelectItem T="int" Value="@c.Id">@c.Name</MudSelectItem>
                        }
                    </MudSelect>
                }
                else if (IsCreate && _centerLabel != null)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@_centerLabel</MudText>
                }

                <MudSelect T="int?" @bind-Value="_form.VendorId"
                           Label="Vendor (optional)"
                           FullWidth="true"
                           Disabled="_loadingVendors">
                    <MudSelectItem T="int?" Value="@((int?)null)">— No Vendor —</MudSelectItem>
                    @foreach (var v in _vendorList)
                    {
                        <MudSelectItem T="int?" Value="@((int?)v.Id)">
                            @v.Name @(v.ContactPerson != null ? $"· {v.ContactPerson}" : "")
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudNumericField @bind-Value="_form.PurchaseCost" Label="@($"Purchase Cost ({CurrencySymbol}) (optional)")"
                                 Format="N2" FullWidth="true" />

                <MudDatePicker @bind-Date="_purchaseDate" Label="Purchase Date (optional)" />

                <ValidationSummary />

                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error">@_error</MudAlert>
                }
            </MudStack>
        </EditForm>
    </DialogContent>

    <DialogActions>
        <MudButton ButtonType="ButtonType.Button" OnClick="Cancel">Cancel</MudButton>
        <MudButton form="eqForm" ButtonType="ButtonType.Submit" Color="Color.Primary"
                   Variant="Variant.Filled" Disabled="_saving">
            @(_saving ? "Saving…" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    public dynamic? MudDialog { get; set; }

    [Parameter]
    public bool IsCreate { get; set; } = true;

    [Parameter]
    public int EquipmentId { get; set; }

    private CreateEquipmentRequest _form = new();
    private List<VendorResponse> _vendorList = new();
    private bool _saving = false;
    private bool _loadingVendors = false;
    private string? _error;
    private DateTime? _purchaseDate;
    private string? _centerLabel;
    private bool _isSuperUser;
    private List<CenterResponse> _centerList = new();
    private bool _loadingCenters;
    private CenterResponse? _headerCenter;
    private string _editCurrencySymbol = "₹";

    private string CurrencySymbol =>
        IsCreate ? (_headerCenter?.CurrencySymbol ?? "₹") : _editCurrencySymbol;

    protected override async Task OnInitializedAsync()
    {
        if (IsCreate)
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            _isSuperUser = auth.User.IsInRole("SuperUser");
            if (_isSuperUser)
            {
                _loadingCenters = true;
                try
                {
                    _centerList = await CenterService.GetAllAsync();
                    if (_centerList.Count > 0)
                    {
                        _form.CenterId = _centerList[0].Id;
                        _headerCenter = _centerList[0];
                    }
                }
                catch { /* snackbar optional */ }
                finally
                {
                    _loadingCenters = false;
                }
            }
            else if (int.TryParse(auth.User.FindFirst("CenterId")?.Value, out var cid) && cid > 0)
            {
                _form.CenterId = cid;
                _centerLabel = "Equipment will be created for your center.";
                try
                {
                    _headerCenter = await CenterService.GetByIdAsync(cid);
                }
                catch { /* optional */ }
            }
        }

        _loadingVendors = true;
        try
        {
            _vendorList = await VendorService.GetAllAsync();
        }
        catch { }
        finally
        {
            _loadingVendors = false;
        }

        if (!IsCreate && EquipmentId > 0)
        {
            var eq = await EquipmentService.GetByIdAsync(EquipmentId);
            if (eq != null)
            {
                _form.Name = eq.Name;
                _form.Category = eq.Category;
                _form.HourlyRate = eq.HourlyRate;
                _form.CenterId = eq.CenterId;
                _form.VendorId = eq.VendorId;
                _form.PurchaseCost = eq.PurchaseCost;
                _purchaseDate = eq.PurchaseDate?.ToLocalTime();
                _editCurrencySymbol = string.IsNullOrWhiteSpace(eq.CurrencySymbol) ? "₹" : eq.CurrencySymbol;
            }
        }
    }

    private Task OnCreateCenterChangedAsync(int value)
    {
        _form.CenterId = value;
        _headerCenter = _centerList.FirstOrDefault(c => c.Id == value);
        return Task.CompletedTask;
    }

    private async Task Save()
    {
        _form.PurchaseDate = _purchaseDate.HasValue ? DateTime.SpecifyKind(_purchaseDate.Value, DateTimeKind.Utc) : null;
        _saving = true;
        _error = null;
        try
        {
            if (IsCreate)
            {
                var (success, error, _) = await EquipmentService.CreateAsync(_form);
                if (success)
                {
                    Snackbar.Add("Equipment created.", Severity.Success);
                    if (MudDialog != null) MudDialog.Close();
                }
                else
                {
                    _error = error;
                }
            }
            else
            {
                var update = new UpdateEquipmentRequest
                {
                    Name = _form.Name,
                    Category = _form.Category,
                    HourlyRate = _form.HourlyRate,
                    VendorId = _form.VendorId,
                    PurchaseCost = _form.PurchaseCost,
                    PurchaseDate = _form.PurchaseDate
                };
                var (success, error, _) = await EquipmentService.UpdateAsync(EquipmentId, update);
                if (success)
                {
                    Snackbar.Add("Equipment updated.", Severity.Success);
                    if (MudDialog != null) MudDialog.Close();
                }
                else
                {
                    _error = error;
                }
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        try { if (MudDialog != null) MudDialog.Cancel(); } catch { }
    }
}
