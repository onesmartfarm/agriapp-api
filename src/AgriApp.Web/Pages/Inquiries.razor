@page "/inquiries"
@using Microsoft.AspNetCore.Components.Authorization
@using AgriApp.Web.Services
@inject IInquiryService InquiryService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<AuthorizeView Roles="SuperUser,Manager,Sales">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
            <MudStack Spacing="3">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h5">CRM / Inquiries</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="OpenCreateDialog"
                               StartIcon="@Icons.Material.Filled.Add">
                        New Inquiry
                    </MudButton>
                </MudStack>

                @if (_loading)
                {
                    <MudProgressCircular indeterminate="true" />
                }
                else if (_inquiries == null || _inquiries.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No inquiries found.</MudAlert>
                }
                else
                {
                    <MudDataGrid Items="_inquiries" Striped="true" Bordered="true" Dense="true" Filterable="true">
                        <Columns>
                            <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" />
                            <PropertyColumn Property="x => x.CustomerName" Title="Customer" Sortable="true" />
                            <TemplateColumn Title="Service" Sortable="true" SortBy="@(x => x.ServiceActivityName)">
                                <CellTemplate Context="svcCtx">
                                    @(string.IsNullOrWhiteSpace(svcCtx.Item.ServiceActivityName) ? "—" : svcCtx.Item.ServiceActivityName)
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Requested equipment" Sortable="true" SortBy="@(x => x.EquipmentName)">
                                <CellTemplate Context="eqCtx">
                                    @(string.IsNullOrWhiteSpace(eqCtx.Item.EquipmentName) ? "—" : eqCtx.Item.EquipmentName)
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="x => x.SalespersonName" Title="Salesperson" Sortable="true" />
                            <PropertyColumn Property="x => x.CenterName" Title="Center" Sortable="true" />
                            <PropertyColumn Property="x => x.Status" Title="Status" Sortable="true">
                                <CellTemplate Context="statusCtx">
                                    <span style="padding: 3px 8px; border-radius: 4px; background-color: @GetStatusColorHex(statusCtx.Item.Status); color: white; font-size: 0.82em;">
                                        @statusCtx.Item.Status
                                    </span>
                                </CellTemplate>
                            </PropertyColumn>
                            <PropertyColumn Property="x => x.CreatedAt" Title="Created" Format="yyyy-MM-dd" Sortable="true" />
                            <TemplateColumn Title="Actions">
                                <CellTemplate Context="actCtx">
                                    <AuthorizeView Roles="Supervisor,Manager,SuperUser">
                                        <Authorized Context="woShortcutAuth">
                                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Assignment"
                                                           title="Create work order from inquiry"
                                                           Color="Color.Primary"
                                                           OnClick="() => OpenWorkOrderFromInquiry(actCtx.Item)" />
                                        </Authorized>
                                    </AuthorizeView>
                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.SwapHoriz"
                                                   title="Update Status"
                                                   Color="Color.Warning"
                                                   OnClick="() => OpenStatusDialog(actCtx.Item)" />
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                }
            </MudStack>
        </MudContainer>
    </Authorized>

    <NotAuthorized>
        <MudAlert Severity="Severity.Error">You do not have permission to access this page.</MudAlert>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<InquiryResponse>? _inquiries;
    private bool _loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadInquiries();
    }

    private async Task LoadInquiries()
    {
        _loading = true;
        try
        {
            _inquiries = await InquiryService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<InquiryDialog>("New Inquiry",
            new DialogParameters<InquiryDialog> { { x => x.IsCreate, true } });
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadInquiries();
    }

    private async Task OpenStatusDialog(InquiryResponse inquiry)
    {
        var parameters = new DialogParameters<InquiryDialog>
        {
            { x => x.IsCreate, false },
            { x => x.InquiryId, inquiry.Id },
            { x => x.CurrentStatus, inquiry.Status }
        };
        var dialog = await DialogService.ShowAsync<InquiryDialog>("Update Inquiry Status", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadInquiries();
    }

    private async Task OpenWorkOrderFromInquiry(InquiryResponse inquiry)
    {
        var parameters = new DialogParameters<WorkOrderDialog>
        {
            { x => x.IsCreate, true },
            { x => x.InitialCenterId, inquiry.CenterId },
            { x => x.InitialCustomerId, inquiry.CustomerId },
            { x => x.InitialServiceActivityId, inquiry.ServiceActivityId },
            { x => x.InitialInquiryId, inquiry.Id },
            { x => x.InitialEquipmentId, inquiry.EquipmentId }
        };
        var dialog = await DialogService.ShowAsync<WorkOrderDialog>("Create Work Order from Inquiry", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadInquiries();
    }

    private string GetStatusColorHex(string status) => status switch
    {
        "New"        => "#2196f3",
        "InProgress" => "#ff9800",
        "Converted"  => "#4caf50",
        "Closed"     => "#9e9e9e",
        _            => "#9e9e9e"
    };
}
