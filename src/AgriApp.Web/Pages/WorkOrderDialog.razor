@using AgriApp.Core.Enums
@using AgriApp.Web.Services
@inject IWorkOrderService WorkOrderService
@inject IEquipmentService EquipmentService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (IsCreate)
        {
            <EditForm id="woCreateForm" Model="_form" OnValidSubmit="SaveCreate">
                <DataAnnotationsValidator />
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_form.Description" Label="Description"
                                  Lines="2" FullWidth="true"
                                  For="@(() => _form.Description)" />

                    <MudSelect @bind-Value="_form.Type" Label="Work Order Type" FullWidth="true">
                        @foreach (var t in Enum.GetValues(typeof(WorkOrderType)).Cast<WorkOrderType>())
                        {
                            <MudSelectItem Value="@t.ToString()">@t</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int?" @bind-Value="_form.EquipmentId" Label="Equipment (optional)"
                               FullWidth="true" Disabled="_loadingEquipment">
                        <MudSelectItem T="int?" Value="@((int?)null)">— None —</MudSelectItem>
                        @foreach (var eq in _equipmentList)
                        {
                            <MudSelectItem T="int?" Value="@((int?)eq.Id)">
                                @eq.Name (@eq.Category) — ₹@eq.HourlyRate.ToString("N0")/hr
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <MudNumericField @bind-Value="_form.ResponsibleUserId"
                                     Label="Responsible User ID"
                                     FullWidth="true"
                                     For="@(() => _form.ResponsibleUserId)" />

                    <MudDatePicker @bind-Date="_startDate" Label="Scheduled Start Date" />
                    <MudTimePicker @bind-Time="_startTime" Label="Start Time" />

                    <MudDatePicker @bind-Date="_endDate" Label="Scheduled End Date" />
                    <MudTimePicker @bind-Time="_endTime" Label="End Time" />

                    <MudNumericField @bind-Value="_form.TotalMaterialCost"
                                     Label="Total Material Cost (₹)"
                                     Format="N2" FullWidth="true"
                                     For="@(() => _form.TotalMaterialCost)" />

                    <ValidationSummary />
                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <MudAlert Severity="Severity.Error">@_error</MudAlert>
                    }
                </MudStack>
            </EditForm>
        }
        else
        {
            <EditForm id="woStatusForm" Model="_statusForm" OnValidSubmit="SaveStatus">
                <DataAnnotationsValidator />
                <MudStack Spacing="3">
                    @if (_detail != null)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            <b>@_detail.Description</b><br />
                            @_detail.Type · @_detail.ScheduledStartDate.ToString("yyyy-MM-dd HH:mm") →
                            @_detail.ScheduledEndDate.ToString("yyyy-MM-dd HH:mm")
                        </MudText>
                        <MudDivider />
                    }

                    <MudSelect @bind-Value="_statusForm.Status" Label="New Status" FullWidth="true">
                        @foreach (var s in Enum.GetValues(typeof(WorkStatus)).Cast<WorkStatus>())
                        {
                            <MudSelectItem Value="@s.ToString()">@s</MudSelectItem>
                        }
                    </MudSelect>

                    <ValidationSummary />
                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <MudAlert Severity="Severity.Error">@_error</MudAlert>
                    }
                </MudStack>
            </EditForm>
        }
    </DialogContent>

    <DialogActions>
        <MudButton ButtonType="ButtonType.Button" OnClick="Cancel">Cancel</MudButton>
        @if (IsCreate)
        {
            <MudButton form="woCreateForm" ButtonType="ButtonType.Submit"
                       Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving">
                @(_saving ? "Creating…" : "Create")
            </MudButton>
        }
        else
        {
            <MudButton form="woStatusForm" ButtonType="ButtonType.Submit"
                       Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving">
                @(_saving ? "Saving…" : "Update Status")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    public dynamic? MudDialog { get; set; }

    [Parameter]
    public bool IsCreate { get; set; } = true;

    [Parameter]
    public int WorkOrderId { get; set; }

    private WorkOrderFormRequest _form = new();
    private WorkOrderStatusUpdateRequest _statusForm = new();
    private WorkOrderDetail? _detail;
    private List<EquipmentResponse> _equipmentList = new();
    private bool _saving = false;
    private bool _loadingEquipment = false;
    private string? _error;

    private DateTime? _startDate = DateTime.Today;
    private TimeSpan? _startTime = TimeSpan.FromHours(8);
    private DateTime? _endDate = DateTime.Today.AddDays(1);
    private TimeSpan? _endTime = TimeSpan.FromHours(17);

    protected override async Task OnInitializedAsync()
    {
        _loadingEquipment = true;
        try
        {
            _equipmentList = await EquipmentService.GetAllAsync();
        }
        finally
        {
            _loadingEquipment = false;
        }

        if (!IsCreate && WorkOrderId > 0)
        {
            _detail = await WorkOrderService.GetByIdAsync(WorkOrderId);
            if (_detail != null)
            {
                _statusForm.Status = _detail.Status;
            }
        }
    }

    private async Task SaveCreate()
    {
        _saving = true;
        _error = null;

        _form.ScheduledStartDate = CombineDateTime(_startDate, _startTime) ?? DateTime.Now;
        _form.ScheduledEndDate = CombineDateTime(_endDate, _endTime) ?? DateTime.Now.AddDays(1);

        try
        {
            var (success, error, _) = await WorkOrderService.CreateAsync(_form);
            if (success)
            {
                Snackbar.Add("Work order created.", Severity.Success);
                if (MudDialog != null) MudDialog.Close();
            }
            else
            {
                _error = error;
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveStatus()
    {
        _saving = true;
        _error = null;
        try
        {
            var (success, error, _) = await WorkOrderService.UpdateStatusAsync(WorkOrderId, _statusForm.Status);
            if (success)
            {
                Snackbar.Add("Work order status updated.", Severity.Success);
                if (MudDialog != null) MudDialog.Close();
            }
            else
            {
                _error = error;
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private static DateTime? CombineDateTime(DateTime? date, TimeSpan? time)
    {
        if (!date.HasValue) return null;
        return date.Value.Date + (time ?? TimeSpan.Zero);
    }

    private void Cancel()
    {
        try { if (MudDialog != null) MudDialog.Cancel(); } catch { }
    }
}
