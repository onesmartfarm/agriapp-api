@using AgriApp.Core.Enums
@using AgriApp.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IWorkOrderService WorkOrderService
@inject IEquipmentService EquipmentService
@inject IUserService UserService
@inject ICustomerService CustomerService
@inject ICenterService CenterService
@inject IServiceActivityService ServiceActivityService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (IsCreate)
        {
            <EditForm id="woCreateForm" Model="_form" OnValidSubmit="SaveCreate">
                <DataAnnotationsValidator />
                <MudStack Spacing="3">

                    @* ── Basic info ─────────────────────────────────────────── *@
                    <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Work Order Details</MudText>

                    <MudTextField @bind-Value="_form.Description" Label="Description"
                                  Lines="2" FullWidth="true"
                                  For="@(() => _form.Description)" />

                    <MudSelect @bind-Value="_form.Type" Label="Work Order Type" FullWidth="true">
                        @foreach (var t in Enum.GetValues(typeof(WorkOrderType)).Cast<WorkOrderType>())
                        {
                            <MudSelectItem Value="@t.ToString()">@t</MudSelectItem>
                        }
                    </MudSelect>

                    @* ── Relational dropdowns ───────────────────────────────── *@
                    @if (IsCreate && _isSuperUser)
                    {
                        <MudSelect T="int" Value="@( _form.CenterId ?? 0 )" ValueChanged="@(async v => await OnWoCenterChangedAsync(v))"
                                   Label="Center"
                                   FullWidth="true" Disabled="_loadingLookups">
                            <MudSelectItem T="int" Value="0">— Select center —</MudSelectItem>
                            @foreach (var c in _centerList)
                            {
                                <MudSelectItem T="int" Value="@c.Id">@c.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }

                    <MudSelect T="int?" Value="_form.ServiceActivityId" ValueChanged="OnServiceActivityChangedAsync"
                               Label="Service activity (optional)"
                               FullWidth="true" Disabled="_loadingLookups || EffectiveCenterId <= 0">
                        <MudSelectItem T="int?" Value="@((int?)null)">— None —</MudSelectItem>
                        @foreach (var a in _serviceActivities)
                        {
                            <MudSelectItem T="int?" Value="@((int?)a.Id)">@a.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <MudNumericField @bind-Value="_serviceHourlyRate"
                                     Label="@($"Billing rate ({_centerCurrencySymbol}/hr) — from selected service")"
                                     Format="N2" FullWidth="true" Disabled="true" />

                    <MudSelect T="int?" @bind-Value="_form.ImplementId"
                               Label="Implement (optional)"
                               FullWidth="true" Disabled="_loadingLookups || EffectiveCenterId <= 0">
                        <MudSelectItem T="int?" Value="@((int?)null)">— None —</MudSelectItem>
                        @foreach (var eq in _implementsForCenter)
                        {
                            <MudSelectItem T="int?" Value="@((int?)eq.Id)">@eq.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int?" @bind-Value="_form.TractorId"
                               Label="Tractor / power unit (optional)"
                               FullWidth="true" Disabled="_loadingLookups || EffectiveCenterId <= 0">
                        <MudSelectItem T="int?" Value="@((int?)null)">— None —</MudSelectItem>
                        @foreach (var eq in _tractorsForCenter)
                        {
                            <MudSelectItem T="int?" Value="@((int?)eq.Id)">@eq.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int" @bind-Value="_form.ResponsibleUserId"
                               Label="Responsible Staff / Supervisor"
                               FullWidth="true" Disabled="_loadingLookups"
                               For="@(() => _form.ResponsibleUserId)">
                        <MudSelectItem T="int" Value="0">— Select User —</MudSelectItem>
                        @foreach (var u in _staffList)
                        {
                            <MudSelectItem T="int" Value="@u.Id">
                                @u.Name (@u.Role)
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int?" @bind-Value="_form.CustomerId"
                               Label="Customer (optional)"
                               FullWidth="true" Disabled="_loadingLookups">
                        <MudSelectItem T="int?" Value="@((int?)null)">— None —</MudSelectItem>
                        @foreach (var c in _customerList)
                        {
                            <MudSelectItem T="int?" Value="@((int?)c.Id)">
                                @c.Name @(c.Phone != null ? $"({c.Phone})" : "")
                            </MudSelectItem>
                        }
                    </MudSelect>

                    @* ── Visual Billing Timeline ────────────────────────────── *@
                    <MudDivider />
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.subtitle2">Work Timeline Spans</MudText>
                        <MudButton ButtonType="ButtonType.Button" Size="Size.Small"
                                   Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddSpan">Add Span</MudButton>
                    </MudStack>

                    @for (int i = 0; i < _spans.Count; i++)
                    {
                        var idx = i;
                        var span = _spans[idx];
                        <MudPaper Elevation="1" Class="pa-2">
                            <MudStack Spacing="2">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudSelect T="string" @bind-Value="span.Type" Label="Type"
                                               Style="min-width:140px">
                                        <MudSelectItem Value='"Working"'>
                                            <span style="color:#4caf50">● Working</span>
                                        </MudSelectItem>
                                        <MudSelectItem Value='"Break"'>
                                            <span style="color:#ff9800">● Break</span>
                                        </MudSelectItem>
                                        <MudSelectItem Value='"Breakdown"'>
                                            <span style="color:#f44336">● Breakdown</span>
                                        </MudSelectItem>
                                    </MudSelect>
                                    <MudDatePicker @bind-Date="span.Date" Label="Date" />
                                    <MudTimePicker @bind-Time="span.Start" Label="Start" />
                                    <MudTimePicker @bind-Time="span.End" Label="End" />
                                    <MudIconButton ButtonType="ButtonType.Button"
                                                   Icon="@Icons.Material.Filled.Remove"
                                                   Color="Color.Error" Size="Size.Small"
                                                   title="Remove span"
                                                   OnClick="() => RemoveSpan(idx)"
                                                   Disabled="_spans.Count <= 1" />
                                </MudStack>
                                <MudTextField @bind-Value="span.Notes" Label="Notes (optional)"
                                              FullWidth="true" />
                            </MudStack>
                        </MudPaper>
                    }

                    @* ── Billing Summary Bar ────────────────────────────────── *@
                    @{
                        var billableHrs = _spans.Where(s => s.IsBillable).Sum(s => s.Hours);
                        var nonBillHrs = _spans.Where(s => !s.IsBillable).Sum(s => s.Hours);
                        var calculatedAmt = _form.ServiceActivityId is int && _serviceHourlyRate > 0
                            ? (decimal)billableHrs * _serviceHourlyRate : 0m;
                    }
                    <MudPaper Elevation="2" Class="pa-3" Style="background-color: #f5f5f5">
                        <MudText Typo="Typo.subtitle2">Billing Summary</MudText>
                        <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap">
                            <MudText>
                                <span style="color:#4caf50; font-weight:600">
                                    @billableHrs.ToString("N1") h
                                </span>
                                <span class="mud-text-secondary"> billable</span>
                            </MudText>
                            <MudText>
                                <span style="color:#9e9e9e; font-weight:600">
                                    @nonBillHrs.ToString("N1") h
                                </span>
                                <span class="mud-text-secondary"> non-billable</span>
                            </MudText>
                            @if (_form.ServiceActivityId is int && calculatedAmt > 0)
                            {
                                <MudText>
                                    <span style="color:#1976d2; font-weight:600">
                                        ≈ @_centerCurrencySymbol@calculatedAmt.ToString("N2")
                                    </span>
                                    <span class="mud-text-secondary">
                                        (@billableHrs.ToString("N1") h × @_centerCurrencySymbol@_serviceHourlyRate.ToString("N2")/hr)
                                    </span>
                                </MudText>
                            }
                            else if (_form.ServiceActivityId == null && billableHrs > 0)
                            {
                                <MudText Class="mud-text-secondary">
                                    Select a service activity for invoice labor (Working hours × service rate + fees).
                                </MudText>
                            }
                        </MudStack>
                    </MudPaper>

                    <MudNumericField @bind-Value="_form.TotalMaterialCost"
                                     Label="@($"Materials / other charges — {_centerCurrencySymbol} (invoice adds service labor from time logs when applicable)")"
                                     Format="N2" FullWidth="true"
                                     For="@(() => _form.TotalMaterialCost)" />

                    <ValidationSummary />
                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <MudAlert Severity="Severity.Error">@_error</MudAlert>
                    }
                </MudStack>
            </EditForm>
        }
        else
        {
            <EditForm id="woStatusForm" Model="_statusForm" OnValidSubmit="SaveStatus">
                <DataAnnotationsValidator />
                <MudStack Spacing="3">
                    @if (_detail != null)
                    {
                        <MudPaper Elevation="0" Class="pa-2" Style="background-color: #f9f9f9; border-radius:4px;">
                            <MudText Typo="Typo.body2"><b>@_detail.Description</b></MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @_detail.Type ·
                                @_detail.ScheduledStartDate.ToString("yyyy-MM-dd HH:mm") →
                                @_detail.ScheduledEndDate.ToString("yyyy-MM-dd HH:mm")
                                · @_detail.CurrencySymbol@_detail.TotalMaterialCost.ToString("N2")
                                · Service: @(_detail.ServiceActivityName ?? "—")
                                · Tractor: @(_detail.TractorName ?? "—") · Implement: @(_detail.ImplementName ?? "—")
                            </MudText>
                        </MudPaper>
                        <MudDivider />
                    }

                    <MudSelect @bind-Value="_statusForm.Status" Label="Update Status" FullWidth="true">
                        @foreach (var s in Enum.GetValues(typeof(WorkStatus)).Cast<WorkStatus>())
                        {
                            <MudSelectItem Value="@s.ToString()">@s</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int?" @bind-Value="_form.CustomerId"
                               Label="Customer (optional)"
                               FullWidth="true"
                               Disabled="_loadingLookups">
                        <MudSelectItem T="int?" Value="@((int?)null)">— None —</MudSelectItem>
                        @foreach (var c in _customerList)
                        {
                            <MudSelectItem T="int?" Value="@((int?)c.Id)">
                                @c.Name @(c.Phone != null ? $"({c.Phone})" : "")
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <ValidationSummary />
                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <MudAlert Severity="Severity.Error">@_error</MudAlert>
                    }
                </MudStack>
            </EditForm>
        }
    </DialogContent>

    <DialogActions>
        <MudButton ButtonType="ButtonType.Button" OnClick="Cancel">Cancel</MudButton>
        @if (IsCreate)
        {
            <MudButton form="woCreateForm" ButtonType="ButtonType.Submit"
                       Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving">
                @(_saving ? "Creating…" : "Create")
            </MudButton>
        }
        else
        {
            <MudButton form="woStatusForm" ButtonType="ButtonType.Submit"
                       Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving">
                @(_saving ? "Saving…" : "Update Status")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    public IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public bool IsCreate { get; set; } = true;

    [Parameter]
    public int WorkOrderId { get; set; }

    private WorkOrderFormRequest _form = new();
    private WorkOrderStatusUpdateRequest _statusForm = new();
    private WorkOrderDetail? _detail;

    private List<EquipmentResponse> _equipmentList = new();
    private List<ServiceActivityRow> _serviceActivities = new();
    private List<CenterResponse> _centerList = new();
    private List<UserResponse> _staffList = new();
    private List<CustomerResponse> _customerList = new();

    private bool _saving = false;
    private bool _loadingLookups = false;
    private string? _error;
    private string _centerCurrencySymbol = "₹";
    private bool _isSuperUser;
    private decimal _serviceHourlyRate;

    private int EffectiveCenterId => _form.CenterId ?? 0;

    private IEnumerable<EquipmentResponse> _implementsForCenter =>
        _equipmentList.Where(e => e.IsImplement && e.CenterId == EffectiveCenterId);

    private IEnumerable<EquipmentResponse> _tractorsForCenter =>
        _equipmentList.Where(e => !e.IsImplement && e.CenterId == EffectiveCenterId);

    private List<SpanEntry> _spans = new() { new SpanEntry() };

    // ── Local span model ──────────────────────────────────────────────────────
    private class SpanEntry
    {
        public string Type { get; set; } = "Working";
        public DateTime? Date { get; set; } = DateTime.Today;
        public TimeSpan? Start { get; set; } = TimeSpan.FromHours(8);
        public TimeSpan? End { get; set; } = TimeSpan.FromHours(17);
        public string Notes { get; set; } = string.Empty;

        public double Hours =>
            (Date.HasValue && Start.HasValue && End.HasValue && End > Start)
                ? (End.Value - Start.Value).TotalHours : 0;

        public bool IsBillable => Type == "Working";

        public DateTime? StartDateTime =>
            Date.HasValue && Start.HasValue ? Date.Value.Date + Start.Value : null;
        public DateTime? EndDateTime =>
            Date.HasValue && End.HasValue ? Date.Value.Date + End.Value : null;
    }

    protected override async Task OnInitializedAsync()
    {
        _loadingLookups = true;
        try
        {
            var equipTask = EquipmentService.GetAllAsync();
            var userTask = UserService.GetAllAsync();
            var customerTask = CustomerService.GetAllAsync();
            await Task.WhenAll(equipTask, userTask, customerTask);
            _equipmentList = await equipTask;
            _customerList = await customerTask;
            var users = await userTask;
            _staffList = users
                .Where(u => u.Role is "Staff" or "Supervisor" or "Manager" or "SuperUser")
                .ToList();

            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            _isSuperUser = auth.User.IsInRole("SuperUser");
            if (_isSuperUser)
            {
                try
                {
                    _centerList = await CenterService.GetAllAsync();
                    if (_form.CenterId is null or 0 && _centerList.Count > 0)
                        _form.CenterId = _centerList[0].Id;
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Could not load centers: {ex.Message}", Severity.Warning);
                }
            }
            else if (int.TryParse(auth.User.FindFirst("CenterId")?.Value, out var centerId) && centerId > 0)
            {
                _form.CenterId = centerId;
            }

            await RefreshServiceActivitiesAndCurrencyAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load lookup data: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _loadingLookups = false;
        }

        if (!IsCreate && WorkOrderId > 0)
        {
            _detail = await WorkOrderService.GetByIdAsync(WorkOrderId);
            if (_detail != null)
            {
                _statusForm.Status = _detail.Status;
                _form.CustomerId = _detail.CustomerId;
                if (!string.IsNullOrWhiteSpace(_detail.CurrencySymbol))
                    _centerCurrencySymbol = _detail.CurrencySymbol;
            }
        }
    }

    private async Task RefreshServiceActivitiesAndCurrencyAsync()
    {
        if (EffectiveCenterId <= 0)
        {
            _serviceActivities = new List<ServiceActivityRow>();
            return;
        }

        try
        {
            _serviceActivities = await ServiceActivityService.GetAllAsync(_isSuperUser ? EffectiveCenterId : null);
            var c = await CenterService.GetByIdAsync(EffectiveCenterId);
            if (c != null && !string.IsNullOrWhiteSpace(c.CurrencySymbol))
                _centerCurrencySymbol = c.CurrencySymbol;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load service activities: {ex.Message}", Severity.Warning);
            _serviceActivities = new List<ServiceActivityRow>();
        }
    }

    private async Task OnWoCenterChangedAsync(int value)
    {
        _form.CenterId = value == 0 ? null : value;
        _form.ServiceActivityId = null;
        _form.ImplementId = null;
        _form.TractorId = null;
        _serviceHourlyRate = 0;
        await RefreshServiceActivitiesAndCurrencyAsync();
    }

    private Task OnServiceActivityChangedAsync(int? id)
    {
        _form.ServiceActivityId = id;
        var a = _serviceActivities.FirstOrDefault(x => x.Id == id);
        _serviceHourlyRate = a?.BaseRatePerHour ?? 0;
        return Task.CompletedTask;
    }

    private void AddSpan() => _spans.Add(new SpanEntry { Date = DateTime.Today });

    private void RemoveSpan(int index)
    {
        if (_spans.Count > 1)
            _spans.RemoveAt(index);
    }

    private async Task SaveCreate()
    {
        _saving = true;
        _error = null;

        // Auto-calculate schedule from spans
        var ordered = _spans
            .Where(s => s.StartDateTime.HasValue)
            .OrderBy(s => s.StartDateTime)
            .ToList();

        if (ordered.Any())
        {
            _form.ScheduledStartDate = ordered.First().StartDateTime!.Value;
            _form.ScheduledEndDate = ordered.Last().EndDateTime
                ?? ordered.Last().StartDateTime!.Value.AddHours(1);
        }
        else
        {
            _form.ScheduledStartDate = DateTime.Now;
            _form.ScheduledEndDate = DateTime.Now.AddDays(1);
        }

        _form.TimeLogs = _spans
            .Where(s => s.StartDateTime.HasValue && s.EndDateTime.HasValue && s.End > s.Start)
            .Select(s => new WorkOrderTimeLogRequest(
                StartTime: DateTime.SpecifyKind(s.StartDateTime!.Value, DateTimeKind.Local).ToUniversalTime(),
                EndTime: DateTime.SpecifyKind(s.EndDateTime!.Value, DateTimeKind.Local).ToUniversalTime(),
                LogType: s.Type,
                Notes: string.IsNullOrWhiteSpace(s.Notes) ? null : s.Notes))
            .ToList();

        try
        {
            var (success, error, _) = await WorkOrderService.CreateAsync(_form);
            if (success)
            {
                Snackbar.Add("Work order created.", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                _error = error;
                Snackbar.Add(error ?? "Failed to create work order.", Severity.Error);
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveStatus()
    {
        _saving = true;
        _error = null;
        try
        {
            var (patchOk, patchErr, _) = await WorkOrderService.UpdateAsync(
                WorkOrderId,
                new WorkOrderPatchRequest(_form.CustomerId));
            if (!patchOk)
            {
                _error = patchErr;
                Snackbar.Add(patchErr ?? "Failed to update work order customer.", Severity.Error);
                return;
            }

            var (success, error, _) = await WorkOrderService.UpdateStatusAsync(WorkOrderId, _statusForm.Status);
            if (success)
            {
                Snackbar.Add("Work order updated.", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                _error = error;
                Snackbar.Add(error ?? "Failed to update status.", Severity.Error);
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog?.Cancel();
}
