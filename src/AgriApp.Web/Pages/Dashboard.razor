@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Dashboard — AgriApp</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">Dashboard</MudText>

<MudGrid>
    <AuthorizeView Roles="Manager,SuperUser">
        <Authorized>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2" Class="dashboard-card">
                    <MudCardContent>
                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.h6" Class="mt-2">Invoices</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Billing & payments</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/invoices" Variant="Variant.Text" Color="Color.Primary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Supervisor,Manager,SuperUser">
        <Authorized>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2" Class="dashboard-card">
                    <MudCardContent>
                        <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Secondary" Size="Size.Large" />
                        <MudText Typo="Typo.h6" Class="mt-2">Work Orders</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Scheduling & status</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/work-orders" Variant="Variant.Text" Color="Color.Primary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Sales,Manager,SuperUser">
        <Authorized>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2" Class="dashboard-card">
                    <MudCardContent>
                        <MudIcon Icon="@Icons.Material.Filled.ContactPhone" Color="Color.Tertiary" Size="Size.Large" />
                        <MudText Typo="Typo.h6" Class="mt-2">CRM / Inquiries</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Customer leads</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/inquiries" Variant="Variant.Text" Color="Color.Primary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Staff,Sales,Supervisor">
        <Authorized>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2" Class="dashboard-card">
                    <MudCardContent>
                        <MudIcon Icon="@Icons.Material.Filled.AccessTime" Color="Color.Success" Size="Size.Large" />
                        <MudText Typo="Typo.h6" Class="mt-2">Attendance</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Clock in / out</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/attendance" Variant="Variant.Text" Color="Color.Primary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </Authorized>
    </AuthorizeView>
</MudGrid>
