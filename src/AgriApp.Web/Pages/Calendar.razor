@page "/calendar"
@using Microsoft.AspNetCore.Components.Authorization
@using AgriApp.Web.Services
@inject ICalendarService CalendarService
@inject ISnackbar Snackbar

<AuthorizeView Roles="Supervisor,Manager,SuperUser">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h5">Equipment Capacity Calendar</MudText>

                @if (_loading)
                {
                    <MudProgressCircular IsIndeterminate="true" />
                }
                else if (_scheduleItems == null || _scheduleItems.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No schedule items available.</MudAlert>
                }
                else
                {
                    <MudPaper Elevation="1" Class="pa-4">
                        <MudSimpleTable Striped="true" Bordered="true" Dense="true">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Equipment</th>
                                    <th>Work Order Count</th>
                                    <th>Total Duration (hrs)</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _scheduleItems.OrderBy(x => x.Date))
                                {
                                    <tr>
                                        <td>@item.Date.ToString("yyyy-MM-dd")</td>
                                        <td>@(item.EquipmentName ?? "N/A")</td>
                                        <td>@item.WorkOrderCount</td>
                                        <td>@item.TotalDurationHours.ToString("F2")</td>
                                        <td>
                                            <span style="padding: 4px 8px; border-radius: 4px; background-color: @GetChipColor(item.UtilizationPercentage);">
                                                @(item.UtilizationPercentage?.ToString("P0") ?? "N/A")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                }
            </MudStack>
        </MudContainer>
    </Authorized>

    <NotAuthorized>
        <MudAlert Severity="Severity.Error">You do not have permission to access this page.</MudAlert>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<CapacityScheduleItem>? _scheduleItems;
    private bool _loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCapacityData();
    }

    private async Task LoadCapacityData()
    {
        _loading = true;
        try
        {
            // Calculate current month's date range
            var today = DateTime.UtcNow;
            var startOfMonth = new DateTime(today.Year, today.Month, 1, 0, 0, 0, DateTimeKind.Utc);
            var endOfMonth = startOfMonth.AddMonths(1);

            _scheduleItems = await CalendarService.GetCenterCapacityAsync(startOfMonth, endOfMonth);

            if (_scheduleItems.Count == 0)
            {
                Snackbar.Add("No schedule data available for this month.", Severity.Info);
            }
        }
        catch (ApplicationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _logger?.LogError(ex, "Failed to load capacity data");
        }
        catch (Exception ex)
        {
            Snackbar.Add("An unexpected error occurred while loading calendar data.", Severity.Error);
            _logger?.LogError(ex, "Unexpected error loading capacity data");
        }
        finally
        {
            _loading = false;
        }
    }

    private Color GetCapacityColor(double? utilization) => utilization switch
    {
        >= 0.9 => Color.Error,    // 90%+ is over-utilized
        >= 0.7 => Color.Warning,  // 70-90% is moderately utilized
        >= 0.5 => Color.Info,     // 50-70% is adequately utilized
        _ => Color.Success         // <50% is under-utilized
    };

    private string GetChipColor(double? utilization) => utilization switch
    {
        >= 0.9 => "#f44336",      // Red for over-utilized
        >= 0.7 => "#ff9800",      // Orange for moderately utilized
        >= 0.5 => "#2196f3",      // Blue for adequately utilized
        _ => "#4caf50"            // Green for under-utilized
    };

    [Inject]
    private ILogger<Calendar> _logger { get; set; } = null!;
}
