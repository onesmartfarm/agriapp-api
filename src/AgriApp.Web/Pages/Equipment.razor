@page "/equipment"
@using Microsoft.AspNetCore.Components.Authorization
@using AgriApp.Core.Enums
@using AgriApp.Web.Services
@inject IEquipmentService EquipmentService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<AuthorizeView Roles="SuperUser,Manager">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
            <MudStack Spacing="3">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h5">Equipment</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="OpenCreateDialog"
                               StartIcon="@Icons.Material.Filled.Add">
                        Add Equipment
                    </MudButton>
                </MudStack>

                @if (_loading)
                {
                    <MudProgressCircular IsIndeterminate="true" />
                }
                else if (_equipment == null || _equipment.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No equipment found.</MudAlert>
                }
                else
                {
                    <MudDataGrid Items="_equipment" Striped="true" Bordered="true" Dense="true" Filterable="true">
                        <Columns>
                            <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" />
                            <PropertyColumn Property="x => x.Name" Title="Name" Sortable="true" />
                            <PropertyColumn Property="x => x.Category" Title="Category" Sortable="true">
                                <CellTemplate Context="catCtx">
                                    <span style="padding: 3px 8px; border-radius: 4px; background-color: @GetCategoryColor(catCtx.Item.Category); color: white; font-size: 0.82em;">
                                        @catCtx.Item.Category
                                    </span>
                                </CellTemplate>
                            </PropertyColumn>
                            <TemplateColumn Title="Hourly Rate" Sortable="true" SortBy="@(x => x.HourlyRate)">
                                <CellTemplate Context="rateCtx">
                                    @rateCtx.Item.CurrencySymbol @rateCtx.Item.HourlyRate.ToString("N2")
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Center" Sortable="true" SortBy="@(x => x.CenterName)">
                                <CellTemplate Context="cenCtx">
                                    @cenCtx.Item.CenterName
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="x => x.CreatedAt" Title="Created" Format="yyyy-MM-dd" Sortable="true" />
                            <TemplateColumn Title="Actions">
                                <CellTemplate Context="actCtx">
                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Calculate"
                                                   Color="Color.Info" title="Get Quote"
                                                   OnClick="() => OpenQuoteDialog(actCtx.Item)" />
                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Edit"
                                                   title="Edit"
                                                   OnClick="() => OpenEditDialog(actCtx.Item.Id)" />
                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error" title="Delete"
                                                   OnClick="() => DeleteEquipment(actCtx.Item.Id)" />
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                }
            </MudStack>
        </MudContainer>
    </Authorized>

    <NotAuthorized>
        <MudAlert Severity="Severity.Error">You do not have permission to access this page.</MudAlert>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<EquipmentResponse>? _equipment;
    private bool _loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadEquipment();
    }

    private async Task LoadEquipment()
    {
        _loading = true;
        try
        {
            _equipment = await EquipmentService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<EquipmentDialog>("Add Equipment",
            new DialogParameters<EquipmentDialog> { { x => x.IsCreate, true } });
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadEquipment();
    }

    private async Task OpenEditDialog(int id)
    {
        var parameters = new DialogParameters<EquipmentDialog>
        {
            { x => x.IsCreate, false },
            { x => x.EquipmentId, id }
        };
        var dialog = await DialogService.ShowAsync<EquipmentDialog>("Edit Equipment", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadEquipment();
    }

    private async Task OpenQuoteDialog(EquipmentResponse eq)
    {
        var parameters = new DialogParameters<EquipmentQuoteDialog>
        {
            { x => x.Equipment, eq }
        };
        await DialogService.ShowAsync<EquipmentQuoteDialog>($"Rental Quote — {eq.Name}", parameters);
    }

    private async Task DeleteEquipment(int id)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Confirm Delete",
            "Delete this equipment? This action cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed == true)
        {
            var (success, error) = await EquipmentService.DeleteAsync(id);
            if (success)
            {
                Snackbar.Add("Equipment deleted.", Severity.Success);
                await LoadEquipment();
            }
            else
            {
                Snackbar.Add($"Error: {error}", Severity.Error);
            }
        }
    }

    private string GetCategoryColor(string category) => category switch
    {
        "Tractor" => "#4caf50",
        "Drone"   => "#2196f3",
        "BioCNG"  => "#ff9800",
        "Vehicle" => "#607d8b",
        _         => "#9e9e9e"
    };
}
