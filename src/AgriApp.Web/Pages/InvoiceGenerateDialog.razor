@using AgriApp.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IInvoiceService InvoiceService
@inject ICenterService CenterService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <EditForm id="genInvForm" Model="_form" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <MudStack Spacing="3">
                <MudNumericField @bind-Value="_form.WorkOrderId" Label="Work Order ID"
                                 FullWidth="true" For="@(() => _form.WorkOrderId)" />
                <MudNumericField @bind-Value="_form.CustomerId" Label="Customer ID"
                                 FullWidth="true" For="@(() => _form.CustomerId)" />
                @if (_isSuperUser)
                {
                    <MudSelect T="int?" Value="_form.CenterId" ValueChanged="OnInvoiceCenterChangedAsync"
                               Label="Center (optional override)"
                               FullWidth="true" Disabled="_loadingCenters">
                        <MudSelectItem T="int?" Value="@((int?)null)">— From your token —</MudSelectItem>
                        @foreach (var c in _centerList)
                        {
                            <MudSelectItem T="int?" Value="@((int?)c.Id)">@c.Name</MudSelectItem>
                        }
                    </MudSelect>
                }
                <MudDatePicker @bind-Date="_dueDate" Label="Due Date" />
                <MudNumericField @bind-Value="_form.AdditionalFees" Label="@($"Additional Fees ({_feeCurrencySymbol})")"
                                 Format="N2" FullWidth="true" For="@(() => _form.AdditionalFees)" />
                <ValidationSummary />
                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error">@_error</MudAlert>
                }
            </MudStack>
        </EditForm>
    </DialogContent>

    <DialogActions>
        <MudButton ButtonType="ButtonType.Button" OnClick="Cancel">Cancel</MudButton>
        <MudButton form="genInvForm" ButtonType="ButtonType.Submit"
                   Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving">
            @(_saving ? "Generating…" : "Generate")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    public dynamic? MudDialog { get; set; }

    private GenerateInvoiceRequest _form = new();
    private DateTime? _dueDate = DateTime.Today.AddDays(30);
    private bool _saving = false;
    private string? _error;
    private bool _isSuperUser;
    private List<CenterResponse> _centerList = new();
    private bool _loadingCenters;
    private string _feeCurrencySymbol = "₹";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _isSuperUser = auth.User.IsInRole("SuperUser");
        if (int.TryParse(auth.User.FindFirst("CenterId")?.Value, out var cid) && cid > 0)
            _form.CenterId = cid;

        if (_isSuperUser)
        {
            _loadingCenters = true;
            try
            {
                _centerList = await CenterService.GetAllAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Could not load centers: {ex.Message}", Severity.Warning);
            }
            finally
            {
                _loadingCenters = false;
            }
        }

        await RefreshFeeCurrencyAsync();
    }

    private async Task OnInvoiceCenterChangedAsync(int? value)
    {
        _form.CenterId = value;
        await RefreshFeeCurrencyAsync();
    }

    private async Task RefreshFeeCurrencyAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var cid = _form.CenterId;
            if (cid is null or 0 && int.TryParse(auth.User.FindFirst("CenterId")?.Value, out var t) && t > 0)
                cid = t;
            if (cid is null or 0)
            {
                _feeCurrencySymbol = "₹";
                return;
            }

            var c = await CenterService.GetByIdAsync(cid.Value);
            if (c != null && !string.IsNullOrWhiteSpace(c.CurrencySymbol))
                _feeCurrencySymbol = c.CurrencySymbol;
        }
        catch
        {
            _feeCurrencySymbol = "₹";
        }
    }

    private async Task Save()
    {
        _saving = true;
        _error = null;
        _form.DueDate = _dueDate ?? DateTime.Today.AddDays(30);
        if (_form.CenterId == 0)
            _form.CenterId = null;
        try
        {
            var (success, error, _) = await InvoiceService.GenerateAsync(_form);
            if (success)
            {
                Snackbar.Add("Invoice generated.", Severity.Success);
                if (MudDialog != null) MudDialog.Close();
            }
            else
            {
                _error = error;
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        try { if (MudDialog != null) MudDialog.Cancel(); } catch { }
    }
}
