<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
        Dashboard
    </MudNavLink>

    @* Clock In/Out — field staff: Staff, Sales, Supervisor *@
    <AuthorizeView Roles="Staff,Sales,Supervisor">
        <Authorized>
            <MudNavLink Href="/attendance" Icon="@Icons.Material.Filled.AccessTime">
                Clock In / Out
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    @* CRM / Inquiries — sales-facing roles *@
    <AuthorizeView Roles="Sales,Manager,SuperUser">
        <Authorized>
            <MudNavLink Href="/inquiries" Icon="@Icons.Material.Filled.ContactPhone">
                CRM / Inquiries
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    @* Capacity Calendar — operational / planning roles *@
    <AuthorizeView Roles="Supervisor,Manager,SuperUser">
        <Authorized>
            <MudNavLink Href="/calendar" Icon="@Icons.Material.Filled.CalendarMonth">
                Capacity Calendar
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    @* Work Orders — operational roles *@
    <AuthorizeView Roles="Supervisor,Manager,SuperUser">
        <Authorized>
            <MudNavLink Href="/work-orders" Icon="@Icons.Material.Filled.Build">
                Work Orders
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    @* Financials & Audit — management only *@
    <AuthorizeView Roles="Manager,SuperUser">
        <Authorized>
            <MudNavGroup Title="Financials & Audit" Icon="@Icons.Material.Filled.AccountBalance" Expanded="false">
                <MudNavLink Href="/invoices" Icon="@Icons.Material.Filled.Receipt">
                    Invoices
                </MudNavLink>
                <MudNavLink Href="/payroll" Icon="@Icons.Material.Filled.Payments">
                    Payroll
                </MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>

    @* Equipment — all logged-in users can view *@
    <MudNavLink Href="/equipment" Icon="@Icons.Material.Filled.Agriculture">
        Equipment
    </MudNavLink>
</MudNavMenu>
