@using Microsoft.AspNetCore.Components.Authorization

<MudNavMenu>
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
                Home
            </MudNavLink>

            <AuthorizeView Roles="Staff,Sales,Supervisor" Context="clockCtx">
                <MudNavLink Href="/attendance" Icon="@Icons.Material.Filled.AccessTime">
                    Clock In / Out
                </MudNavLink>
            </AuthorizeView>

            <AuthorizeView Roles="Sales,Manager,SuperUser" Context="crmCtx">
                <MudNavLink Href="/inquiries" Icon="@Icons.Material.Filled.People">
                    CRM / Inquiries
                </MudNavLink>
            </AuthorizeView>

            <AuthorizeView Roles="Supervisor,Manager,SuperUser" Context="woCtx">
                <MudNavLink Href="/workorders" Icon="@Icons.Material.Filled.Assignment">
                    Work Orders
                </MudNavLink>
            </AuthorizeView>

            <AuthorizeView Roles="Supervisor,Manager,SuperUser" Context="calCtx">
                <MudNavLink Href="/calendar" Icon="@Icons.Material.Filled.CalendarMonth">
                    Capacity Calendar
                </MudNavLink>
            </AuthorizeView>

            <AuthorizeView Roles="SuperUser,Manager" Context="eqCtx">
                <MudNavLink Href="/equipment" Icon="@Icons.Material.Filled.Agriculture">
                    Equipment
                </MudNavLink>
                <MudNavLink Href="/services" Icon="@Icons.Material.Filled.HomeRepairService">
                    Service activities
                </MudNavLink>
            </AuthorizeView>

            <AuthorizeView Roles="SuperUser,Manager" Context="invCtx">
                <MudNavLink Href="/invoices" Icon="@Icons.Material.Filled.Receipt">
                    Invoices
                </MudNavLink>
            </AuthorizeView>

            <AuthorizeView Roles="Manager,SuperUser" Context="finCtx">
                <MudNavLink Href="/financials" Icon="@Icons.Material.Filled.AccountBalance">
                    Financials &amp; Audit
                </MudNavLink>
            </AuthorizeView>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>
