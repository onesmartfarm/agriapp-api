@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudContainer MaxWidth="MaxWidth.False" Style="min-height:100vh;background:linear-gradient(135deg,#2E7D32 0%,#1B5E20 100%);">
    @Body
</MudContainer>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#2E7D32",
            Secondary = "#FFA000",
            AppbarBackground = "#2E7D32"
        }
    };
}
